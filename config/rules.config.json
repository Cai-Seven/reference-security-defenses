{
  "maxPackageAgeDays": 14,
  "description": "NPM 包供应链安全规则配置",
  "rules": {
    "enabled": true,
    "blockNewPackages": true,
    "strictMode": false
  },
  "overrides": {
    "description": "特定包的覆盖规则",
    "@babel/core": {
      "maxPackageAgeDays": 7,
      "reason": "核心依赖，需要更严格检查"
    },
    "react": {
      "maxPackageAgeDays": 21,
      "reason": "重型库，发布频率可能较慢"
    }
  },
  "excludedPatterns": [
    "description: 完全排除某些包的检查",
    "@types/*",
    "*-mock",
    "*-stub"
  ],
  "registry": {
    "primary": "https://registry.npmjs.org",
    "fallback": "https://registry.npmjs.org",
    "timeout": 10000
  }
}
